# =====================================================================
#  ARQUIVO DE CHAVES DE API  (MODELO)
# ---------------------------------------------------------------------
#  Como usar:
#   1) Faça uma CÓPIA deste arquivo e renomeie a cópia para  .env
#      (sem nada antes do ponto, só ".env")
#   2) Preencha os valores entre aspas com as chaves reais.
#   3) Salve. Pronto — a ferramenta passa do modo DEMONSTRAÇÃO
#      para o modo REAL automaticamente.
#
#  NUNCA compartilhe o arquivo .env preenchido: ele é a "senha"
#  de acesso às contas.
# =====================================================================

# Modo de dados: "demo" = dados simulados (para testar a tela)
#                "real" = puxa dados verdadeiros das APIs
# Deixe "demo" enquanto não tiver as chaves.
MODO_DADOS=demo

# ---------------------------------------------------------------------
#  INSTAGRAM / FACEBOOK  (Meta Graph API)
# ---------------------------------------------------------------------
# Token de acesso de longa duração gerado no Meta for Developers.
META_ACCESS_TOKEN=""

# ID da conta comercial do Instagram (Instagram Business Account ID)
# do artista. Cada artista tem o seu.
IG_BUSINESS_ID_BAILACO=""

# (Futuro) ID da Página do Facebook do artista.
FB_PAGE_ID_BAILACO=""

# ---------------------------------------------------------------------
#  (FUTURO) YOUTUBE  — Google / YouTube Data + Analytics API
# ---------------------------------------------------------------------
YOUTUBE_API_KEY=""
YOUTUBE_CHANNEL_ID_BAILACO=""

# ---------------------------------------------------------------------
#  (FUTURO) TIKTOK  — TikTok for Business / Display API
# ---------------------------------------------------------------------
TIKTOK_ACCESS_TOKEN=""
TIKTOK_ACCOUNT_ID_BAILACO=""
